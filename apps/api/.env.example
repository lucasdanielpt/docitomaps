# Copie este arquivo para `.env` e preencha com valores reais.

# Porta do backend (somente dev local)
PORT=8787

# Origem permitida do frontend (CORS). Em produção na Vercel, o domínio
# *.vercel.app é aceito automaticamente; adicione aqui domínio customizado se tiver.
CORS_ORIGIN=http://localhost:5173

# Log level do Fastify (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# --------------------------------------------------------------
# OpenRouteService — https://openrouteservice.org/dev/#/signup
# Crie uma conta gratuita e cole a "API Key" abaixo.
# Free tier: 2.000 req/dia, 40 req/min.
#
# Na Vercel: Project Settings → Environment Variables → ORS_API_KEY
# --------------------------------------------------------------
ORS_API_KEY=

# Base URL do OpenRouteService (não altere sem motivo)
ORS_BASE_URL=https://api.openrouteservice.org
