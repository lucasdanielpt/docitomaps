{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/cesiumStatic/(.*)\\.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    }
  ],
  "functions": {
    "api/health.ts": {
      "maxDuration": 10
    },
    "api/[...path].ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "api/handler.cjs"
    }
  }
}
