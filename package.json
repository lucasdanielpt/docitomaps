{
  "name": "docitomapas",
  "version": "1.0.0",
  "private": true,
  "description": "Guia 3D de Roteiros de Viagem",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:web": "pnpm --filter @docitomapas/web run dev",
    "dev:api": "pnpm --filter @docitomapas/api run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
